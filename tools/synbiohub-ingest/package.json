{
  "name": "@seqora/synbiohub-ingest",
  "version": "0.1.0",
  "private": true,
  "description": "One-way ingest from public SynBioHub instances into a Seqora pending-claim manifest.",
  "type": "module",
  "bin": {
    "seqora-synbiohub-ingest": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@seqora/canonicalize": "file:../../packages/canonicalize"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
