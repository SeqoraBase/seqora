#!/usr/bin/env bash
#
# Pre-push hygiene check — scans all commits in the push range.
# Belt-and-suspenders in case commit-msg hook was bypassed.

ZERO="0000000000000000000000000000000000000000"
BLOCKED='(claude|anthropic|openai|copilot|gpt-|chatgpt|llm|ai.generat|ai.assist)'

while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "$ZERO" ]; then
        continue
    fi

    if [ "$remote_sha" = "$ZERO" ]; then
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    if git log --format="%B" "$range" 2>/dev/null | grep -qiE "$BLOCKED"; then
        echo "ERROR: Push blocked — commit message contains prohibited reference."
        echo "       Rewrite the offending commit(s) before pushing."
        exit 1
    fi

    if git log --format="%an %ae %cn %ce" "$range" 2>/dev/null | grep -qiE "$BLOCKED"; then
        echo "ERROR: Push blocked — commit author/committer contains prohibited reference."
        exit 1
    fi
done

exit 0
