#!/usr/bin/env bash
#
# Reject commits that credit AI tools as author or co-author.
# Enforced via core.hooksPath = .githooks (set in repo setup).

MSG_FILE="$1"

if grep -qiE '(claude|anthropic|co-authored-by.*noreply@anthropic)' "$MSG_FILE"; then
    echo "ERROR: Commit message contains a prohibited author/co-author reference."
    echo "       Remove any Co-authored-by lines referencing AI tools."
    exit 1
fi

AUTHOR_NAME=$(git var GIT_AUTHOR_IDENT 2>/dev/null | sed 's/ <.*//')
AUTHOR_EMAIL=$(git var GIT_AUTHOR_IDENT 2>/dev/null | sed 's/.*<//;s/>.*//')

if echo "$AUTHOR_NAME $AUTHOR_EMAIL" | grep -qiE '(claude|anthropic)'; then
    echo "ERROR: Author name or email contains a prohibited reference."
    exit 1
fi
