#!/usr/bin/env bash
#
# Commit message hygiene hook.
# Enforced via core.hooksPath = .githooks (set in repo setup).

MSG_FILE="$1"

BLOCKED='(claude|anthropic|co-authored-by.*noreply@anthropic|openai|copilot|gpt-|chatgpt|llm|ai.generat|ai.assist)'

if grep -qiE "$BLOCKED" "$MSG_FILE"; then
    echo "ERROR: Commit message contains a prohibited reference."
    echo "       Clean up the message and try again."
    exit 1
fi

AUTHOR_NAME=$(git var GIT_AUTHOR_IDENT 2>/dev/null | sed 's/ <.*//')
AUTHOR_EMAIL=$(git var GIT_AUTHOR_IDENT 2>/dev/null | sed 's/.*<//;s/>.*//')

if echo "$AUTHOR_NAME $AUTHOR_EMAIL" | grep -qiE "$BLOCKED"; then
    echo "ERROR: Author name or email contains a prohibited reference."
    exit 1
fi
