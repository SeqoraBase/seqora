#!/usr/bin/env bash
#
# Pre-commit: check Solidity formatting before commit.

# Only run if Solidity files are staged
if git diff --cached --name-only --diff-filter=ACM | grep -q '\.sol$'; then
    if command -v forge &>/dev/null; then
        cd contracts 2>/dev/null || exit 0
        if ! forge fmt --check 2>/dev/null; then
            echo "ERROR: Solidity formatting check failed."
            echo "       Run 'forge fmt' in contracts/ and re-stage."
            exit 1
        fi
    fi
fi
