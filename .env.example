# Seqora — environment variable template
# Copy to `.env` and fill in secrets. NEVER commit `.env`.

# ---- RPC endpoints ----
# Base mainnet RPC (Alchemy / Infura / Coinbase Node / public)
BASE_RPC_URL=

# Base Sepolia testnet RPC
BASE_SEPOLIA_RPC_URL=

# ---- Deployment ----
# Private key used for `forge script` deploys. Use an ephemeral throwaway for testnet.
DEPLOYER_PRIVATE_KEY=

# ---- Verification ----
# Basescan API key (works for both mainnet + sepolia)
BASESCAN_API_KEY=

# ---- Integrations ----
# EAS SchemaRegistry address on the target chain (Base: 0x4200...; placeholder until confirmed)
EAS_SCHEMA_REGISTRY=

# ---- Timelock governance (set for DeployTimelock / TransferOwnershipToTimelock scripts) ----
# Deployed TimelockController address (filled after running DeployTimelock.s.sol)
TIMELOCK=
# Min delay in seconds for the Timelock (e.g. 172800 = 48h). Also used as scheduleBatch delay.
TIMELOCK_MIN_DELAY=172800
# Address granted PROPOSER_ROLE + CANCELLER_ROLE. Typically the deployer EOA or a multisig.
TIMELOCK_PROPOSER=
# Unique non-zero salt for the handover scheduleBatch operation (any bytes32, e.g. keccak of "seqora-handover-v1").
TIMELOCK_SALT=

# ---- Deployed contract addresses (filled after DeploySeqora) ----
SCREENING_ATTESTATIONS=
LICENSE_REGISTRY=
ROYALTY_ROUTER=
PROVENANCE_REGISTRY=
BIOSAFETY_COURT=
ATTESTER=
GOVERNANCE=
TREASURY=
SAFETY_COUNCIL=
SCREENING_SCHEMA_UID=
BASE_URI=
